{
  "schemaVersion": 2,
  "type": "training_plan",
  "planId": "beginner-gym-bodyweight-mix-v2",
  "name": "Beginner Gym + Lichaamsgewicht Mix",
  "description": "Rustig en praktisch startschema voor een beginner. Gericht op basiskracht, consistentie en lage drempel. Mix van sportschool en lichaamsgewichtoefeningen.",
  "goal": "Basiskracht en trainingsroutine opbouwen",
  "level": "beginner",
  "locationType": "gym",
  "equipment": [
    "leg press of squat rack",
    "bench press of chest press machine",
    "lat pulldown machine",
    "row machine or cable row",
    "dumbbells",
    "mat"
  ],
  "schedule": {
    "targetSessionsPerWeek": 3,
    "minRecoveryHours": 48,
    "preferredDays": ["monday", "wednesday", "friday"],
    "defaultSessionOrder": ["full-body-a", "full-body-b"],
    "recommendedPattern": "A-B-A, volgende week B-A-B",
    "estimatedWeeklyMinutes": 135,
    "adaptiveScheduling": true
  },
  "recoveryRules": {
    "trafficLightEnabled": true,
    "green": {
      "label": "goed moment om te trainen",
      "rule": "48 uur of meer sinds vorige sessie"
    },
    "orange": {
      "label": "kan, maar rustig aan",
      "rule": "24 tot 48 uur sinds vorige sessie of lichte vermoeidheid"
    },
    "red": {
      "label": "beter rust nemen",
      "rule": "minder dan 24 uur sinds vorige sessie of duidelijke spierpijn/vermoeidheid"
    }
  },
  "progressionRules": {
    "method": "double_progression",
    "globalRule": "Als alle sets aan de bovenkant van de herhalingsrange gehaald worden met goede vorm, verhoog dan de volgende keer het gewicht licht.",
    "weightIncreaseGuidance": {
      "upperBodyKg": 2.0,
      "lowerBodyKg": 5.0
    },
    "notes": [
      "Techniek gaat voor gewicht",
      "Train niet tot complete uitputting",
      "Laatste 2 herhalingen mogen zwaar voelen maar moeten haalbaar blijven"
    ]
  },
  "completionRules": {
    "exerciseCompletionMode": "manual_check",
    "allowDirectExerciseCompletion": true,
    "sessionCompletionMode": "all_exercises_checked_or_manual_override",
    "sessionStatuses": ["completed", "partial", "skipped"]
  },
  "successMilestones": [
    {
      "milestoneId": "first-workout",
      "name": "Eerste training voltooid",
      "condition": "completed_sessions >= 1"
    },
    {
      "milestoneId": "five-workouts",
      "name": "Vijf trainingen gehaald",
      "condition": "completed_sessions >= 5"
    },
    {
      "milestoneId": "first-full-session",
      "name": "Eerste volledige sessie afgevinkt",
      "condition": "completed_full_sessions >= 1"
    },
    {
      "milestoneId": "weekly-goal-once",
      "name": "Weekdoel gehaald",
      "condition": "weeks_goal_met >= 1"
    },
    {
      "milestoneId": "three-weeks-consistent",
      "name": "Drie weken consistent",
      "condition": "weeks_goal_met >= 3"
    }
